@startuml RemoteAccessModule
skinparam classAttributeIconSize 0
hide empty methods
hide empty fields
skinparam NoteBackgroundColor #FFFFE0
skinparam NoteBorderColor black

package "xconv2.remote_access" {
  class RemoteLoggingConfiguration {
    level: int
    trace_filesystem: bool
    trace_file_io: bool
  }

  

  class RemoteEntry {
    path: str
    name: str
    is_dir: bool
    size: int?
    is_link: bool
  }

  class RemoteFilesystemSpec {
    protocol: str
    storage_options: dict
    root_path: str
    display_name: str
    uri_scheme: str
    uri_authority: str
    proxy_jump: str?
  }

  class RemoteAccessSession {
    +configure_logging(...)
    +logging_configuration()
    +list_entries(path)
    +read_fields(...)
    +close()
  }

  note left of RemoteAccessSession
  Primary facade used by the worker.
  Holds no network state itself;
  it operates on a prepared filesystem.
  end note

  class _ConfiguredRemoteFileSystem
  class _LoggingFileHandleProxy
  class _XconvHostKeyPolicy

  class "Descriptor + URI helpers" as DescriptorHelpers <<utility>>
  class "Entry + dataset normalization" as NormalizationHelpers <<utility>>
  class "Cache + logging wrappers" as CacheHelpers <<utility>>
  class "Filesystem construction" as FilesystemHelpers <<utility>>

  note right of FilesystemHelpers
  build_remote_filesystem_spec()
  create_filesystem()
  _create_sftp_via_jump()
end note

  RemoteAccessSession --> RemoteLoggingConfiguration : shared runtime config
  RemoteAccessSession --> RemoteEntry : returns
  RemoteAccessSession ..> NormalizationHelpers : uses
  DescriptorHelpers --> RemoteFilesystemSpec : build / parse
  NormalizationHelpers --> RemoteEntry : normalize / filter
  FilesystemHelpers --> RemoteFilesystemSpec : consumes
  FilesystemHelpers ..> CacheHelpers : wraps
  FilesystemHelpers ..> _XconvHostKeyPolicy : ProxyJump SSH
  CacheHelpers ..> _ConfiguredRemoteFileSystem : memory cache defaults
  CacheHelpers ..> _LoggingFileHandleProxy : file I/O tracing
}




@enduml
